# Copier vers .env sur votre machine ou définir ces variables sur Render / Fly / Docker.
# Ne commitez jamais de fichier .env avec des secrets réels.

# Port d’écoute (Render/Fly injectent souvent PORT automatiquement).
# PORT=10000

# Écouter sur toutes les interfaces (obligatoire derrière un reverse proxy en prod).
INVOOBLAST_SMTP_RELAY_HOST=0.0.0.0

# Port si pas de variable PORT (développement local).
# INVOOBLAST_SMTP_RELAY_PORT=18765

# Secret partagé : même valeur dans l’app Paramètres → Clé API relais.
# INVOOBLAST_RELAY_API_KEY=

# Origines autorisées (CORS), séparées par des virgules — URL exacte du site (GitHub Pages).
# INVOOBLAST_ALLOWED_ORIGINS=https://votrecompte.github.io,https://votrecompte.github.io/nom-repo
